# 应用配置
DEBUG=True
PORT=8081

# 日志（structlog + stdlib；见 logging_config.py）
# LOG_LEVEL: DEBUG/INFO/WARNING/ERROR/CRITICAL
LOG_LEVEL=INFO
# 文件日志路径（LOG_ENABLE_FILE=true 时写入；目录不存在会自动创建）
LOG_FILE=./logs/app.log
# true 时 stdout/文件为 JSON 行，便于集中采集；false 为控制台友好彩色文本
LOG_JSON=false
# false 时仅 stdout，适合容器/演示（由平台采集日志）
LOG_ENABLE_FILE=true

# 角色初始化
INIT_BUILTIN_ROLES_ON_START=True
ROLES_CONFIG_PATH=config/roles.yaml

# CORS配置（多个域名用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 大模型配置
MODEL_BASE_URL=http://127.0.0.1:1234
MODEL_API_KEY=key
MODEL_NAME=model

# 响应设置
STREAM_DELAY=0.02

# TTS配置
TTS_TRITON_URL=http://localhost:8000
TTS_MODEL_NAME=cosyvoice2
TTS_REQUEST_TIMEOUT=30

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./app.db
# true 时将执行的 SQL 打到日志
SQLALCHEMY_ECHO=false

# 认证 / JWT 配置
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis / TTS 缓存配置
REDIS_URL=redis://localhost:6379/0
TTS_CACHE_TTL_SECONDS=3600