# 应用配置
DEBUG=True
LOG_LEVEL=trace
PORT=8081

# 角色初始化
INIT_BUILTIN_ROLES_ON_START=True
ROLES_CONFIG_PATH=config/roles.yaml

# CORS配置（多个域名用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 大模型配置
MODEL_BASE_URL=http://127.0.0.1:1234
MODEL_API_KEY=key
MODEL_NAME=model

# 响应设置
STREAM_DELAY=0.02

# TTS配置
TTS_TRITON_URL=http://localhost:8000
TTS_MODEL_NAME=cosyvoice2
TTS_REQUEST_TIMEOUT=30

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./app.db

# 认证 / JWT 配置
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Redis / TTS 缓存配置
REDIS_URL=redis://localhost:6379/0
TTS_CACHE_TTL_SECONDS=3600